# Anthropic API Key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Path to the Python executable (use venv path for isolated env)
# Windows example: C:\Users\joao\Documents\01-projetos-2026\Transcripta\python\.venv\Scripts\python.exe
# macOS/Linux example: /usr/bin/python3
PYTHON_PATH=python

# Whisper model size: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL=large-v3

# Compute device: cpu | cuda | auto
WHISPER_DEVICE=auto

# Compute type: int8 | int8_float16 | float16 | float32
WHISPER_COMPUTE=int8_float16
